# =============================================================================
# snaq-verify — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your API keys.
# All three keys are required for a real run.

# --- USDA FoodData Central -------------------------------------------------
# Sign up: https://fdc.nal.usda.gov/api-key-signup/
# Free, instant. Rate limit: 1000 req/hr per IP with key.
USDA_API_KEY=

# --- OpenAI ----------------------------------------------------------------
# Get a key: https://platform.openai.com/api-keys
# Used by: the verifier agent (orchestrates tool calls) and the judge agent.
OPENAI_API_KEY=

# --- Tavily Search ---------------------------------------------------------
# Sign up: https://tavily.com (free tier: 1000 credits/month)
# Used by: web_search_nutrition tool when USDA + OFF both miss.
TAVILY_API_KEY=

# --- Optional overrides ----------------------------------------------------
# OPENAI_MODEL=gpt-5.1
# OFF_USER_AGENT=snaq-verify/0.1 (your.email@example.com)
# CACHE_DIR=.cache
# LOG_LEVEL=INFO
